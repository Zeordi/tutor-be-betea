{
  "version": 2,
  "buildCommand": "npx prisma generate && npx nest build",
  "installCommand": "npm install --include=dev",
  "functions": {
    "api/index.ts": {
      "maxDuration": 60,
      "includeFiles": "{prisma/**,node_modules/.prisma/**,node_modules/@prisma/client/**,dist/**}"
    }
  },
  "rewrites": [{ "source": "/(.*)", "destination": "/api" }],
  "regions": ["iad1"]
}
