    "@nestjs/platform-socket.io": "^10.3.10",
    "@nestjs/throttler": "^5.2.0",
    "@nestjs/websockets": "^10.3.10",
    "@prisma/client": "^5.17.0",
    "bcrypt": "^5.1.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nodemailer": "^6.9.14",
