// prisma/schema.prisma
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserType {
  PARENT
  TEACHER
  ADMIN
}

enum VerificationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  DISPUTED
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
  REFUND_PENDING
}

enum NotificationType {
  BOOKING
  MESSAGE
  PAYMENT
  SYSTEM
  VERIFICATION
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  CLOSED
  REFUNDED
}

model User {
  id               String         @id @default(uuid())
  email            String         @unique
  passwordHash     String
  fullName         String
  phone            String         @unique
  userType         UserType
  isVerified       Boolean        @default(false)
  isActive         Boolean        @default(true)
  location         Json? // PostGIS point stored as JSON
  profileImage     String?
  stripeCustomerId String?
  lastLoginAt      DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  // Relations
  teacherProfile   TeacherProfile?
  bookings         Booking[]      @relation("ParentBookings")
  messages         Message[]      @relation("SenderMessages")
  receivedMessages Message[]      @relation("ReceiverMessages")
  reviews          Review[]       @relation("ReviewerReviews")
  notifications    Notification[]
  favorites        Favorite[]
  auditLogs        AuditLog[]
  disputesRaised   Dispute[]      @relation("DisputeRaisedBy")
  disputesResolved Dispute[]      @relation("DisputeResolvedBy")
  sessions         Session[]

  @@index([email])
  @@index([userType])
  @@index([isActive])
}

model TeacherProfile {
  id                 String             @id @default(uuid())
  userId             String             @unique
  bio                String?
  hourlyRate         Decimal            @db.Decimal(10, 2)
  serviceRadiusKm    Int                @default(5)
  verificationStatus VerificationStatus @default(PENDING)
  avgRating          Decimal            @default(0) @db.Decimal(3, 2)
  totalReviews       Int                @default(0)
  subjects           Json               @default("[]")
  introVideoUrl      String?
  isAvailable        Boolean            @default(true)
  stripeAccountId    String?
  totalEarnings      Decimal            @default(0) @db.Decimal(10, 2)
  totalStudents      Int                @default(0)
  experienceYears    Int                @default(0)
  education          Json               @default("[]")
  languages          Json               @default("[]")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  // Relations
  user               User               @relation(fields: [userId], references: [id])
  availability       Availability[]
  bookings           Booking[]
  reviews            Review[]
  verificationLogs   VerificationLog[]
  favorites          Favorite[]

  @@index([verificationStatus])
  @@index([avgRating])
  @@index([hourlyRate])
  @@index([isAvailable])
}

model Availability {
  id           String         @id @default(uuid())
  teacherId    String
  dayOfWeek    Int // 0-6 (Sunday-Saturday)
  startTime    String // HH:MM format
  endTime      String // HH:MM format
  isRecurring  Boolean        @default(true)
  dateOverride DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])

  @@unique([teacherId, dayOfWeek, startTime, endTime])
  @@index([teacherId])
  @@index([dayOfWeek])
}

model Booking {
  id                 String         @id @default(uuid())
  teacherId          String
  parentId           String
  studentName        String
  studentAge         Int
  learningGoals      String?
  bookingDate        DateTime
  startTime          String // HH:MM format
  endTime            String // HH:MM format
  durationHours      Decimal        @db.Decimal(3, 1)
  status             BookingStatus  @default(PENDING)
  totalAmount        Decimal        @db.Decimal(10, 2)
  platformFee        Decimal        @db.Decimal(10, 2)
  teacherPayout      Decimal        @db.Decimal(10, 2)
  isTrialLesson      Boolean        @default(false)
  zoomMeetingLink    String?
  meetingPassword    String?
  cancellationReason String?
  cancelledAt        DateTime?
  completedAt        DateTime?
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  // Relations
  teacher            TeacherProfile @relation(fields: [teacherId], references: [id])
  parent             User           @relation("ParentBookings", fields: [parentId], references: [id])
  messages           Message[]
  payments           Payment[]
  reviews            Review[]
  disputes           Dispute[]

  @@index([teacherId])
  @@index([parentId])
  @@index([status])
  @@index([bookingDate])
  @@index([startTime])
}

model Payment {
  id                  String        @id @default(uuid())
  bookingId           String
  stripePaymentIntent String        @unique
  amount              Decimal       @db.Decimal(10, 2)
  status              PaymentStatus @default(PENDING)
  paymentMethod       String
  transactionId       String?
  refundId            String?
  refundAmount        Decimal?      @db.Decimal(10, 2)
  metadata            Json?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Relations
  booking             Booking       @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([stripePaymentIntent])
  @@index([status])
}

model Message {
  id             String    @id @default(uuid())
  bookingId      String
  senderId       String
  receiverId     String
  message        String
  attachmentUrl  String?
  attachmentType String?
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  // Relations
  booking        Booking   @relation(fields: [bookingId], references: [id])
  sender         User      @relation("SenderMessages", fields: [senderId], references: [id])
  receiver       User      @relation("ReceiverMessages", fields: [receiverId], references: [id])

  @@index([bookingId])
  @@index([senderId])
  @@index([receiverId])
  @@index([createdAt])
  @@index([isRead])
}

model Review {
  id           String         @id @default(uuid())
  bookingId    String         @unique
  reviewerId   String
  teacherId    String
  rating       Int // 1-5
  reviewText   String?
  isPublic     Boolean        @default(true)
  isVerified   Boolean        @default(false)
  adminFlagged Boolean        @default(false)
  adminNotes   String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  // Relations
  booking      Booking        @relation(fields: [bookingId], references: [id])
  reviewer     User           @relation("ReviewerReviews", fields: [reviewerId], references: [id])
  teacher      TeacherProfile @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
  @@index([reviewerId])
  @@index([rating])
  @@index([isPublic])
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  data        Json?
  isRead      Boolean          @default(false)
  readAt      DateTime?
  sentAt      DateTime         @default(now())
  deliveredAt DateTime?

  // Relations
  user        User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([isRead])
  @@index([sentAt])
  @@index([type])
}

model VerificationLog {
  id               String             @id @default(uuid())
  teacherId        String
  verificationType String // ID, CERTIFICATE, BACKGROUND
  status           VerificationStatus @default(PENDING)
  documentUrls     Json               @default("[]")
  veriffSessionId  String?
  veriffStatus     String?
  reviewedBy       String?
  reviewNotes      String?
  rejectionReason  String?
  expiresAt        DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  // Relations
  teacher          TeacherProfile     @relation(fields: [teacherId], references: [id])

  @@index([teacherId])
  @@index([status])
  @@index([veriffSessionId])
}

model Favorite {
  id        String         @id @default(uuid())
  parentId  String
  teacherId String
  createdAt DateTime       @default(now())

  // Relations
  parent    User           @relation(fields: [parentId], references: [id])
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  @@unique([parentId, teacherId])
  @@index([parentId])
  @@index([teacherId])
}

model Dispute {
  id                String        @id @default(uuid())
  bookingId         String
  raisedBy          String
  reason            String
  description       String?
  status            DisputeStatus @default(OPEN)
  resolvedBy        String?
  resolution        String?
  resolutionDetails String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  resolvedAt        DateTime?

  // Relations
  booking           Booking       @relation(fields: [bookingId], references: [id])
  raisedByUser      User          @relation("DisputeRaisedBy", fields: [raisedBy], references: [id])
  resolvedByUser    User?         @relation("DisputeResolvedBy", fields: [resolvedBy], references: [id])

  @@index([bookingId])
  @@index([status])
  @@index([raisedBy])
}

model AuditLog {
  id           String   @id @default(uuid())
  userId       String?
  action       String
  resourceType String
  resourceId   String?
  changes      Json?
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Relations
  user         User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([resourceType])
  @@index([createdAt])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  // Relations
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
}
